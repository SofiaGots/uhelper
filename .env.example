# Environment
ENVIRONMENT=development  # development | production | testing

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI-compatible API Configuration
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1  # или ваш базовый URL
OPENAI_PROJECT_ID=your_openai_project_id_here  # опционально
OPENAI_MODEL=gpt-3.5-turbo

# Database / Cache
DATABASE_URL=sqlite:///uhelper.db
REDIS_URL=redis://localhost:6379/0  # опционально, если используете rate limiting/кэш

# Network/timeouts
REQUEST_TIMEOUT_SECONDS=15
